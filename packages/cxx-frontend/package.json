{
  "name": "cxx-frontend",
  "version": "1.1.27",
  "description": "A compiler front end for the C++ language",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wasm": "./dist/wasm/cxx-js.wasm"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "browser": {
    "url": false
  },
  "scripts": {
    "watch": "watchexec --print-events -r npm run build",
    "build": "tsc",
    "docs": "typedoc src/index.ts",
    "prettier": "npx prettier --check .",
    "prettier:fix": "npx prettier --write . "
  },
  "keywords": [
    "c++",
    "compiler",
    "lexer",
    "parser",
    "preprocessor",
    "syntax"
  ],
  "author": {
    "name": "Roberto Raggi",
    "email": "roberto.raggi@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertoraggi/cplusplus.git"
  },
  "bugs": {
    "url": "https://github.com/robertoraggi/cplusplus/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2"
  }
}
